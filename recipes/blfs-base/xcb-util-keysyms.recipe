pkg_name="xcb-util-keysyms"
pkg_version="0.4.1"
source_archive="xcb-util-keysyms-0.4.1.tar.xz"
source_dir="xcb-util-keysyms-0.4.1"

build_recipe() {
  ./configure --prefix=/usr        \
              --sysconfdir=/etc    \
              --localstatedir=/var \
              --disable-static
  make
  make install
}
