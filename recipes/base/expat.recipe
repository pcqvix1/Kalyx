pkg_name="expat"
pkg_version="2.7.4"
source_archive="expat-2.7.4.tar.xz"
source_dir="expat-2.7.4"

build_recipe() {
  ./configure --prefix=/usr    \
              --disable-static \
              --docdir=/usr/share/doc/expat-2.7.4

  make

  if [[ "${KALYX_RUN_TESTS:-0}" == "1" ]]; then
    make check
  fi

  make install
  install -v -m644 doc/*.{html,css} /usr/share/doc/expat-2.7.4
}

