pkg_name="polkit-gnome"
pkg_version="0.105"
source_archive="polkit-gnome-0.105.tar.xz"
source_dir="polkit-gnome-0.105"
extra_archives=(
  "polkit-gnome-0.105-consolidated_fixes-1.patch"
)

build_recipe() {
  patch -Np1 -i /sources/polkit-gnome-0.105-consolidated_fixes-1.patch

  ./configure --prefix=/usr
  make
  make install

  install -vdm755 /etc/xdg/autostart
  cat > /etc/xdg/autostart/polkit-gnome-authentication-agent-1.desktop <<'EOF'
[Desktop Entry]
Name=PolicyKit Authentication Agent
Comment=PolicyKit Authentication Agent
Exec=/usr/libexec/polkit-gnome-authentication-agent-1
Terminal=false
Type=Application
Categories=
NoDisplay=true
OnlyShowIn=GNOME;XFCE;Unity;
AutostartCondition=GNOME3 unless-session gnome
EOF
}
