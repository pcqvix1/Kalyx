pkg_name="libtasn1"
pkg_version="4.21.0"
source_archive="libtasn1-4.21.0.tar.gz"
source_dir="libtasn1-4.21.0"

build_recipe() {
  ./configure --prefix=/usr --disable-static
  make

  if [[ "${KALYX_RUN_TESTS:-0}" == "1" ]]; then
    make check
  fi

  make install
  make -C doc/reference install-data-local
}
