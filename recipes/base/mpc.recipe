pkg_name="mpc"
pkg_version="1.3.1"
source_archive="mpc-1.3.1.tar.gz"
source_dir="mpc-1.3.1"

build_recipe() {
  ./configure --prefix=/usr    \
              --disable-static \
              --docdir=/usr/share/doc/mpc-1.3.1

  make
  make html

  if [[ "${KALYX_RUN_TESTS:-0}" == "1" ]]; then
    make check
  fi

  make install
  make install-html
}

