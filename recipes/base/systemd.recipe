pkg_name="systemd"
pkg_version="259.1"
source_archive="systemd-259.1.tar.gz"
source_dir="systemd-259.1"
extra_archives=("systemd-man-pages-259.1.tar.xz")

build_recipe() {
  sed -e 's/GROUP="render"/GROUP="video"/' \
      -e 's/GROUP="sgx", //'               \
      -i rules.d/50-udev-default.rules.in

  mkdir -p build
  cd build

  meson setup ..                \
        --prefix=/usr           \
        --buildtype=release     \
        -D default-dnssec=no    \
        -D firstboot=false      \
        -D install-tests=false  \
        -D ldconfig=false       \
        -D sysusers=false       \
        -D rpmmacrosdir=no      \
        -D homed=disabled       \
        -D man=disabled         \
        -D mode=release         \
        -D pamconfdir=no        \
        -D dev-kvm-mode=0660    \
        -D nobody-group=nogroup \
        -D sysupdate=disabled   \
        -D ukify=disabled       \
        -D docdir=/usr/share/doc/systemd-259.1

  ninja

  if [[ "${KALYX_RUN_TESTS:-0}" == "1" ]]; then
    echo 'NAME="Kalyx"' > /etc/os-release
    unshare -m ninja test || true
  fi

  ninja install
  tar -xf /sources/systemd-man-pages-259.1.tar.xz \
      --no-same-owner --strip-components=1        \
      -C /usr/share/man

  systemd-machine-id-setup
  systemctl preset-all
}

