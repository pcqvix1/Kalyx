pkg_name="binutils-pass2"
pkg_version="2.46.0"
source_archive="binutils-2.46.0.tar.xz"
source_dir="binutils-2.46.0"

build_recipe() {
  sed '6031s/$add_dir//' -i ltmain.sh

  mkdir -v build
  cd build

  ../configure \
    --prefix=/usr \
    --build="$(../config.guess)" \
    --host="$LFS_TGT" \
    --disable-nls \
    --enable-shared \
    --enable-gprofng=no \
    --disable-werror \
    --enable-64-bit-bfd \
    --enable-new-dtags \
    --enable-default-hash-style=gnu

  make
  make DESTDIR="$LFS" install

  rm -v "$LFS"/usr/lib/lib{bfd,ctf,ctf-nobfd,opcodes,sframe}.{a,la}
}

