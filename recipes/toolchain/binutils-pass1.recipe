pkg_name="binutils-pass1"
pkg_version="2.46.0"
source_archive="binutils-2.46.0.tar.xz"
source_dir="binutils-2.46.0"

build_recipe() {
  mkdir -v build
  cd build

  ../configure --prefix="$LFS/tools" \
               --with-sysroot="$LFS" \
               --target="$LFS_TGT" \
               --disable-nls \
               --enable-gprofng=no \
               --disable-werror \
               --enable-new-dtags \
               --enable-default-hash-style=gnu

  make
  make install
}

