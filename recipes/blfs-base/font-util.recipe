pkg_name="font-util"
pkg_version="1.4.1"
source_archive="font-util-1.4.1.tar.xz"
source_dir="font-util-1.4.1"

build_recipe() {
  export XORG_PREFIX="/usr"
  export XORG_CONFIG="--prefix=$XORG_PREFIX --sysconfdir=/etc --localstatedir=/var --disable-static"

  ./configure $XORG_CONFIG
  make
  make install
}
