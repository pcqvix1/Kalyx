#!/usr/bin/env bash
set -Eeuo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"
# shellcheck source=lib/common.sh
source "$SCRIPT_DIR/lib/common.sh"

require_linux
ensure_linux_build_path "$KALYX_WORKDIR"
ensure_dirs

[[ -d "$KALYX_ROOTFS/etc" ]] || die "Rootfs nao preparado. Rode scripts/prepare-rootfs primeiro."

info "Instalando interface XFCE reduzida da Kalyx em $KALYX_ROOTFS"

skel_xfconf="$KALYX_ROOTFS/etc/skel/.config/xfce4/xfconf/xfce-perchannel-xml"
mkdir -p \
  "$skel_xfconf" \
  "$KALYX_ROOTFS/etc/skel/.config/autostart" \
  "$KALYX_ROOTFS/usr/local/bin" \
  "$KALYX_ROOTFS/usr/share/applications" \
  "$KALYX_ROOTFS/etc/polkit-1/rules.d"

install -m 0755 "$KALYX_REPO/desktop/kalyx-time-config" "$KALYX_ROOTFS/usr/local/bin/kalyx-time-config"
install -m 0644 "$KALYX_REPO/desktop/xfce4-panel.xml" "$skel_xfconf/xfce4-panel.xml"
install -m 0644 "$KALYX_REPO/desktop/xfce4-desktop.xml" "$skel_xfconf/xfce4-desktop.xml"

cat > "$KALYX_ROOTFS/etc/skel/.dmrc" <<'DMRC'
[Desktop]
Session=xfce
DMRC

cat > "$KALYX_ROOTFS/etc/skel/.config/autostart/kalyx-polkit-agent.desktop" <<'POLKIT_AGENT'
[Desktop Entry]
Type=Application
Name=PolicyKit Agent
Exec=/usr/libexec/polkit-gnome-authentication-agent-1
OnlyShowIn=XFCE;
NoDisplay=true
X-GNOME-Autostart-enabled=true
POLKIT_AGENT

cat > "$KALYX_ROOTFS/usr/local/bin/kalyx-time-config-launcher" <<'LAUNCHER'
#!/usr/bin/env sh
set -eu

if [ -n "${KALYX_TIME_CONFIG_IN_TERMINAL:-}" ]; then
  exec /usr/local/bin/kalyx-time-config
fi

if [ -n "${DISPLAY:-}" ] && command -v zenity >/dev/null 2>&1; then
  exec /usr/local/bin/kalyx-time-config
fi

if [ -n "${DISPLAY:-}" ] && command -v xfce4-terminal >/dev/null 2>&1; then
  exec xfce4-terminal --title="Kalyx Data e Hora" --command="env KALYX_TIME_CONFIG_IN_TERMINAL=1 /usr/local/bin/kalyx-time-config"
fi

if [ -n "${DISPLAY:-}" ] && command -v xterm >/dev/null 2>&1; then
  exec xterm -T "Kalyx Data e Hora" -e env KALYX_TIME_CONFIG_IN_TERMINAL=1 /usr/local/bin/kalyx-time-config
fi

exec /usr/local/bin/kalyx-time-config
LAUNCHER
chmod 0755 "$KALYX_ROOTFS/usr/local/bin/kalyx-time-config-launcher"

cat > "$KALYX_ROOTFS/usr/share/applications/kalyx-time-config.desktop" <<DESKTOP
[Desktop Entry]
Type=Application
Name=Config
Comment=Configurar data, hora e timezone
Exec=/usr/local/bin/kalyx-time-config-launcher
Terminal=false
Categories=Settings;System;
DESKTOP

cat > "$KALYX_ROOTFS/etc/polkit-1/rules.d/49-kalyx-time.rules" <<'POLKIT'
polkit.addRule(function(action, subject) {
  if ((action.id == "org.freedesktop.timedate1.set-time" ||
       action.id == "org.freedesktop.timedate1.set-timezone" ||
       action.id == "org.freedesktop.timedate1.set-ntp") &&
      subject.isInGroup("wheel")) {
    return polkit.Result.AUTH_ADMIN;
  }
});
POLKIT

info "Interface reduzida pronta: painel com data/hora e botao Config."
