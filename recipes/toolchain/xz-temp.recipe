pkg_name="xz-temp"
pkg_version="5.8.2"
source_archive="xz-5.8.2.tar.xz"
source_dir="xz-5.8.2"

build_recipe() {
  ./configure --prefix=/usr \
              --host="$LFS_TGT" \
              --build="$(build-aux/config.guess)" \
              --disable-static \
              --docdir=/usr/share/doc/xz-5.8.2

  make
  make DESTDIR="$LFS" install
  rm -v "$LFS/usr/lib/liblzma.la"
}

