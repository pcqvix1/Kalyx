pkg_name="binutils-final"
pkg_version="2.46.0"
source_archive="binutils-2.46.0.tar.xz"
source_dir="binutils-2.46.0"

build_recipe() {
  mkdir -v build
  cd build

  ../configure --prefix=/usr       \
               --sysconfdir=/etc   \
               --enable-ld=default \
               --enable-plugins    \
               --enable-shared     \
               --disable-werror    \
               --enable-64-bit-bfd \
               --enable-new-dtags  \
               --with-system-zlib  \
               --enable-default-hash-style=gnu

  make tooldir=/usr

  if [[ "${KALYX_RUN_TESTS:-1}" != "0" ]]; then
    make -k check
    grep '^FAIL:' "$(find -name '*.log')" || true
  fi

  make tooldir=/usr install

  rm -rfv /usr/lib/lib{bfd,ctf,ctf-nobfd,gprofng,opcodes,sframe}.a \
          /usr/share/doc/gprofng/
}

