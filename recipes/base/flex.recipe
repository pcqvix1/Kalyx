pkg_name="flex"
pkg_version="2.6.4"
source_archive="flex-2.6.4.tar.gz"
source_dir="flex-2.6.4"

build_recipe() {
  ./configure --prefix=/usr    \
              --disable-static \
              --docdir=/usr/share/doc/flex-2.6.4

  make

  if [[ "${KALYX_RUN_TESTS:-0}" == "1" ]]; then
    make check
  fi

  make install
  ln -sv flex   /usr/bin/lex
  ln -sv flex.1 /usr/share/man/man1/lex.1
}

