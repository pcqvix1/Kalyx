pkg_name="bash"
pkg_version="5.3"
source_archive="bash-5.3.tar.gz"
source_dir="bash-5.3"

build_recipe() {
  ./configure --prefix=/usr             \
              --without-bash-malloc     \
              --with-installed-readline \
              --docdir=/usr/share/doc/bash-5.3

  make

  if [[ "${KALYX_RUN_TESTS:-0}" == "1" ]]; then
    chown -R tester .
    su -s /usr/bin/expect tester <<'TEST'
set timeout -1
spawn make tests
expect eof
lassign [wait] _ _ _ value
exit $value
TEST
  fi

  make install
}

