pkg_name="sqlite"
pkg_version="3510200"
source_archive="sqlite-autoconf-3510200.tar.gz"
source_dir="sqlite-autoconf-3510200"
extra_archives=("sqlite-doc-3510200.tar.xz")

build_recipe() {
  tar -xf /sources/sqlite-doc-3510200.tar.xz

  ./configure --prefix=/usr     \
              --disable-static  \
              --enable-fts{4,5} \
              CPPFLAGS="-D SQLITE_ENABLE_COLUMN_METADATA=1 \
                        -D SQLITE_ENABLE_UNLOCK_NOTIFY=1   \
                        -D SQLITE_ENABLE_DBSTAT_VTAB=1     \
                        -D SQLITE_SECURE_DELETE=1"

  make LDFLAGS.rpath=""
  make install

  install -v -m755 -d /usr/share/doc/sqlite-3.51.2
  cp -v -R sqlite-doc-3510200/* /usr/share/doc/sqlite-3.51.2
}

