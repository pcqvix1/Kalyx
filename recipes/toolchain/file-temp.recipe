pkg_name="file-temp"
pkg_version="5.46"
source_archive="file-5.46.tar.gz"
source_dir="file-5.46"

build_recipe() {
  mkdir build
  pushd build
    ../configure --disable-bzlib \
                 --disable-libseccomp \
                 --disable-xzlib \
                 --disable-zlib
    make
  popd

  ./configure --prefix=/usr \
              --host="$LFS_TGT" \
              --build="$(./config.guess)"

  make FILE_COMPILE="$(pwd)/build/src/file"
  make DESTDIR="$LFS" install
  rm -v "$LFS/usr/lib/libmagic.la"
}

