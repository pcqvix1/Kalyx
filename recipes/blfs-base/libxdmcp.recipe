pkg_name="libxdmcp"
pkg_version="1.1.5"
source_archive="libXdmcp-1.1.5.tar.xz"
source_dir="libXdmcp-1.1.5"

build_recipe() {
  ./configure --prefix=/usr        \
              --sysconfdir=/etc    \
              --localstatedir=/var \
              --disable-static
  make

  if [[ "${KALYX_RUN_TESTS:-0}" == "1" ]]; then
    make check
  fi

  make install
}
