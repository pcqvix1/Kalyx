pkg_name="man-db"
pkg_version="2.13.1"
source_archive="man-db-2.13.1.tar.xz"
source_dir="man-db-2.13.1"

build_recipe() {
  ./configure --prefix=/usr                         \
              --docdir=/usr/share/doc/man-db-2.13.1 \
              --sysconfdir=/etc                     \
              --disable-setuid                      \
              --enable-cache-owner=bin              \
              --with-browser=/usr/bin/lynx          \
              --with-vgrind=/usr/bin/vgrind         \
              --with-grap=/usr/bin/grap

  make

  if [[ "${KALYX_RUN_TESTS:-0}" == "1" ]]; then
    make check
  fi

  make install
}

