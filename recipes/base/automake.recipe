pkg_name="automake"
pkg_version="1.18.1"
source_archive="automake-1.18.1.tar.xz"
source_dir="automake-1.18.1"

build_recipe() {
  ./configure --prefix=/usr --docdir=/usr/share/doc/automake-1.18.1
  make

  if [[ "${KALYX_RUN_TESTS:-0}" == "1" ]]; then
    make -j"$(($(nproc)>4?$(nproc):4))" check
  fi

  make install
}

