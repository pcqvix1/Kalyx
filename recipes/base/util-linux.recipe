pkg_name="util-linux"
pkg_version="2.41.3"
source_archive="util-linux-2.41.3.tar.xz"
source_dir="util-linux-2.41.3"

build_recipe() {
  ./configure --bindir=/usr/bin     \
              --libdir=/usr/lib     \
              --runstatedir=/run    \
              --sbindir=/usr/sbin   \
              --disable-chfn-chsh   \
              --disable-login       \
              --disable-nologin     \
              --disable-su          \
              --disable-setpriv     \
              --disable-runuser     \
              --disable-pylibmount  \
              --disable-liblastlog2 \
              --disable-static      \
              --without-python      \
              ADJTIME_PATH=/var/lib/hwclock/adjtime \
              --docdir=/usr/share/doc/util-linux-2.41.3

  make

  if [[ "${KALYX_RUN_TESTS:-0}" == "1" ]]; then
    touch /etc/fstab
    chown -R tester .
    su tester -c "make -k check"
  fi

  make install
}

