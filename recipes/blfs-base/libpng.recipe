pkg_name="libpng"
pkg_version="1.6.55"
source_archive="libpng-1.6.55.tar.xz"
source_dir="libpng-1.6.55"
extra_archives=("libpng-1.6.54-apng.patch")

build_recipe() {
  patch -Np1 -i /sources/libpng-1.6.54-apng.patch

  ./configure --prefix=/usr --disable-static
  make

  if [[ "${KALYX_RUN_TESTS:-0}" == "1" ]]; then
    make check
  fi

  make install
  mkdir -v /usr/share/doc/libpng-1.6.55
  cp -v README libpng-manual.txt /usr/share/doc/libpng-1.6.55
}
