pkg_name="gettext"
pkg_version="1.0"
source_archive="gettext-1.0.tar.xz"
source_dir="gettext-1.0"

build_recipe() {
  ./configure --prefix=/usr    \
              --disable-static \
              --docdir=/usr/share/doc/gettext-1.0

  make

  if [[ "${KALYX_RUN_TESTS:-0}" == "1" ]]; then
    make check
  fi

  make install
  chmod -v 0755 /usr/lib/preloadable_libintl.so
}

