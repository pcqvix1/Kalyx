#!/bin/busybox sh

set -u

PATH=/bin:/sbin:/usr/bin:/usr/sbin
export PATH

panic() {
  echo "Kalyx boot initramfs: $*" >&2
  echo "cmdline: $(cat /proc/cmdline 2>/dev/null || true)" >&2
  echo "partitions:" >&2
  cat /proc/partitions >&2 2>/dev/null || true
  echo "devices:" >&2
  ls -l /dev >&2 2>/dev/null || true
  echo "Abrindo shell de emergencia." >&2
  exec sh
}

mkdir -p /proc /sys /dev /run /newroot
mount -t proc proc /proc || panic "falha ao montar /proc"
mount -t sysfs sysfs /sys || panic "falha ao montar /sys"
mount -t devtmpfs devtmpfs /dev 2>/dev/null || mount -t tmpfs devtmpfs /dev || panic "falha ao montar /dev"
mount -t tmpfs tmpfs /run 2>/dev/null || true
mdev -s 2>/dev/null || true

cmdline="$(cat /proc/cmdline)"
root_arg=""

for arg in $cmdline; do
  case "$arg" in
    root=*) root_arg="${arg#root=}" ;;
  esac
done

[ -n "$root_arg" ] || panic "parametro root= ausente"

for module in virtio_pci virtio_blk ahci libahci ata_piix sd_mod scsi_mod ext4 vfat nls_cp437 nls_iso8859_1; do
  modprobe "$module" 2>/dev/null || true
done

tries=0
root_dev=""
while [ "$tries" -lt 60 ]; do
  mdev -s 2>/dev/null || true

  case "$root_arg" in
    UUID=*) root_dev="$(blkid -U "${root_arg#UUID=}" 2>/dev/null || true)" ;;
    LABEL=*) root_dev="$(blkid -L "${root_arg#LABEL=}" 2>/dev/null || true)" ;;
    /dev/*) root_dev="$root_arg" ;;
    *) root_dev="" ;;
  esac

  [ -z "$root_dev" ] && root_dev="$(blkid -L KALYX_ROOT 2>/dev/null || true)"
  [ -n "$root_dev" ] && [ -b "$root_dev" ] && break
  sleep 1
  tries=$((tries + 1))
done

if [ -z "$root_dev" ]; then
  for candidate in /dev/sd*[0-9] /dev/vd*[0-9] /dev/xvd*[0-9] /dev/nvme*n*p[0-9]; do
    [ -b "$candidate" ] || continue
    if mount -o rw "$candidate" /newroot 2>/dev/null; then
      if [ -x /newroot/sbin/init ] || [ -x /newroot/usr/lib/systemd/systemd ]; then
        root_dev="$candidate"
        break
      fi
      umount /newroot 2>/dev/null || true
    fi
  done
fi

[ -n "$root_dev" ] || panic "nao encontrei root device: $root_arg"

mountpoint -q /newroot 2>/dev/null || mount -o rw "$root_dev" /newroot || panic "falha ao montar raiz $root_dev"

for dir in proc sys dev run; do
  if [ ! -d "/newroot/$dir" ]; then
    mkdir -p "/newroot/$dir" || panic "falha ao criar /$dir na raiz real"
  fi
done

if [ ! -x /newroot/sbin/init ] && [ ! -x /newroot/usr/lib/systemd/systemd ]; then
  panic "init da raiz real nao encontrado"
fi

mount --move /proc /newroot/proc || panic "falha ao mover /proc"
mount --move /sys /newroot/sys || panic "falha ao mover /sys"
mount --move /dev /newroot/dev || panic "falha ao mover /dev"
mount --move /run /newroot/run || panic "falha ao mover /run"

exec switch_root /newroot /sbin/init
