#!/usr/bin/env bash
set -Eeuo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" >/dev/null 2>&1 && pwd)"
# shellcheck source=lib/common.sh
source "$SCRIPT_DIR/lib/common.sh"

phase="${1:-}"
[[ -n "$phase" ]] || die "Uso: bash scripts/run-recipe-phase <toolchain|base|desktop>"

recipe_dir="$KALYX_REPO/recipes/$phase"
[[ -d "$recipe_dir" ]] || die "Diretorio de receitas nao encontrado: $recipe_dir"

manifest="$recipe_dir/manifest"
recipes=()

if [[ -f "$manifest" ]]; then
  missing_after=0
  while IFS= read -r entry; do
    [[ -z "$entry" || "$entry" == \#* ]] && continue
    recipe="$recipe_dir/$entry.recipe"
    if [[ ! -f "$recipe" ]]; then
      warn "Receita ainda nao implementada: $recipe"
      warn "Parando a fase '$phase' no primeiro pacote ausente."
      missing_after=1
      break
    fi
    recipes+=("$recipe")
  done < "$manifest"
else
  mapfile -t recipes < <(find "$recipe_dir" -maxdepth 1 -type f -name '*.recipe' | sort)
fi

if [[ "${#recipes[@]}" -eq 0 ]]; then
  warn "Nenhuma receita em $recipe_dir."
  warn "A fase '$phase' esta pronta para receber receitas, mas ainda nao compila pacotes reais."
  exit 0
fi

for recipe in "${recipes[@]}"; do
  run_logged "lfs-$(basename "$recipe" .recipe)" bash "$KALYX_REPO/scripts/lfs-build-recipe" "$recipe"
done

if [[ "${missing_after:-0}" -eq 1 ]]; then
  warn "Fase '$phase' parcialmente concluida. Continue implementando a proxima receita do manifesto."
  exit 0
fi

info "Fase '$phase' concluida."
