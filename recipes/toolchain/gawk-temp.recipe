pkg_name="gawk-temp"
pkg_version="5.3.2"
source_archive="gawk-5.3.2.tar.xz"
source_dir="gawk-5.3.2"

build_recipe() {
  sed -i 's/extras//' Makefile.in

  ./configure --prefix=/usr \
              --host="$LFS_TGT" \
              --build="$(build-aux/config.guess)"

  make
  make DESTDIR="$LFS" install
}

