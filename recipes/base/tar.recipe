pkg_name="tar"
pkg_version="1.35"
source_archive="tar-1.35.tar.xz"
source_dir="tar-1.35"

build_recipe() {
  FORCE_UNSAFE_CONFIGURE=1 ./configure --prefix=/usr
  make

  if [[ "${KALYX_RUN_TESTS:-0}" == "1" ]]; then
    make check
  fi

  make install
  make -C doc install-html docdir=/usr/share/doc/tar-1.35
}

