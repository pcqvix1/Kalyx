pkg_name="freetype-harfbuzz"
pkg_version="2.14.1"
source_archive="freetype-2.14.1.tar.xz"
source_dir="freetype-2.14.1"
extra_archives=("freetype-doc-2.14.1.tar.xz")

build_recipe() {
  tar -xf /sources/freetype-doc-2.14.1.tar.xz --strip-components=2 -C docs

  sed -ri "s:.*(AUX_MODULES.*valid):\1:" modules.cfg

  sed -r "s:.*(#.*SUBPIXEL_RENDERING) .*:\1:" \
      -i include/freetype/config/ftoption.h

  ./configure --prefix=/usr            \
              --disable-static         \
              --enable-freetype-config \
              --with-harfbuzz=yes

  make
  make install

  cp -v -R docs -T /usr/share/doc/freetype-2.14.1
  rm -vf /usr/share/doc/freetype-2.14.1/freetype-config.1
}
