#!/bin/busybox sh

set -eu

PATH=/bin:/sbin:/usr/bin:/usr/sbin
export PATH

panic() {
  echo "Kalyx initramfs: $*" >&2
  exec sh
}

mkdir -p /proc /sys /dev /run /newroot
mount -t proc proc /proc || panic "falha ao montar /proc"
mount -t sysfs sysfs /sys || panic "falha ao montar /sys"
mount -t devtmpfs devtmpfs /dev 2>/dev/null || mount -t tmpfs devtmpfs /dev || panic "falha ao montar /dev"
[ -e /dev/console ] || mknod /dev/console c 5 1 2>/dev/null || true
[ -e /dev/null ] || mknod /dev/null c 1 3 2>/dev/null || true
exec </dev/console >/dev/console 2>&1
mdev -s 2>/dev/null || true

cmdline="$(cat /proc/cmdline)"
iso_label="KALYX_LIVE"
debug=0

for arg in $cmdline; do
  case "$arg" in
    live.label=*) iso_label="${arg#live.label=}" ;;
    kalyx.debug=1) debug=1 ;;
  esac
done

[ "$debug" = "1" ] && set -x
echo "Kalyx initramfs: iniciando boot live"
echo "Kalyx initramfs: cmdline: $cmdline"

mkdir -p /run/live/medium /run/live/rootfs /run/live/overlay /run/live/work

for module in virtio_pci virtio_blk ahci libahci ata_piix sr_mod cdrom sd_mod scsi_mod isofs iso9660 squashfs overlay loop vfat nls_cp437 nls_iso8859_1; do
  modprobe "$module" 2>/dev/null || true
done

tries=0
live_dev=""
while [ "$tries" -lt 60 ]; do
  mdev -s 2>/dev/null || true
  live_dev="$(blkid -L "$iso_label" 2>/dev/null || true)"
  [ -n "$live_dev" ] && break
  [ "$debug" = "1" ] && echo "Kalyx initramfs: aguardando midia live '$iso_label' ($tries/60)"
  sleep 1
  tries=$((tries + 1))
done

[ -n "$live_dev" ] || panic "nao encontrei midia live com label $iso_label"

echo "Kalyx initramfs: midia live encontrada em $live_dev"
mount -o ro "$live_dev" /run/live/medium || panic "falha ao montar midia live"
[ -f /run/live/medium/live/rootfs.squashfs ] || panic "rootfs.squashfs ausente"

echo "Kalyx initramfs: montando squashfs e overlay"
mount -t squashfs -o loop,ro /run/live/medium/live/rootfs.squashfs /run/live/rootfs || panic "falha ao montar squashfs"
mount -t tmpfs tmpfs /run/live/overlay || panic "falha ao montar tmpfs overlay"
mkdir -p /run/live/overlay/upper /run/live/overlay/work
mount -t overlay overlay \
  -o lowerdir=/run/live/rootfs,upperdir=/run/live/overlay/upper,workdir=/run/live/overlay/work \
  /newroot || panic "falha ao montar overlay"

mkdir -p /newroot/run/live
mount --move /run/live /newroot/run/live
mount --move /proc /newroot/proc
mount --move /sys /newroot/sys
mount --move /dev /newroot/dev

echo "Kalyx initramfs: iniciando systemd"
exec switch_root /newroot /sbin/init
