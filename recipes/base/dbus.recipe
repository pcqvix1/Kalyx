pkg_name="dbus"
pkg_version="1.16.2"
source_archive="dbus-1.16.2.tar.xz"
source_dir="dbus-1.16.2"

build_recipe() {
  mkdir build
  cd build

  meson setup --prefix=/usr --buildtype=release --wrap-mode=nofallback ..
  ninja

  if [[ "${KALYX_RUN_TESTS:-0}" == "1" ]]; then
    ninja test
  fi

  ninja install
  ln -sfv /etc/machine-id /var/lib/dbus
}

