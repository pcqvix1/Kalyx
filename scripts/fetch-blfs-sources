declare -A source_urls=()
declare -A source_sha256s=()
declare -A source_md5s=()
failed_downloads=()

register_source_url() {
  local filename="$1"
  local url="$2"
  local existing registered

  [[ -n "$filename" && -n "$url" ]] || return 0

  existing="${source_urls[$filename]:-}"
  while IFS= read -r registered; do
    [[ "$registered" == "$url" ]] && return 0
  done <<< "$existing"

  if [[ -n "$existing" ]]; then
    source_urls["$filename"]+=$'\n'"$url"
  else
    source_urls["$filename"]="$url"
  fi
}

register_xorg_source() {
  local section="$1"
  local md5="$2"
  local filename="$3"

  source_md5s["$filename"]="$md5"
  register_source_url "$filename" "https://xorg.freedesktop.org/archive/individual/$section/$filename"
  register_source_url "$filename" "https://www.x.org/archive/individual/$section/$filename"
  register_source_url "$filename" "https://www.x.org/releases/individual/$section/$filename"
  register_source_url "$filename" "https://xorg.freedesktop.org/releases/individual/$section/$filename"
  register_source_url "$filename" "https://cdn.netbsd.org/pub/pkgsrc/distfiles/$filename"

  case "$filename" in
    smproxy-1.0.8.tar.xz)
      register_source_url "$filename" "https://gentoo.osuosl.org/distfiles/7b/$filename"
      register_source_url "$filename" "https://ftp.osuosl.org/pub/gentoo/distfiles/7b/$filename"
      ;;
  esac
}

register_known_sources() {
  local item filename url sha256 fallback_url md5

  while IFS= read -r url; do
    [[ -z "$url" || "$url" == \#* ]] && continue
    filename="${url##*/}"
    register_source_url "$filename" "$url"
  done < "$BLFS_SOURCES/wget-list"

  for item in "${extra_sources[@]}"; do
    IFS='|' read -r filename url sha256 fallback_url <<<"$item"
    register_source_url "$filename" "$url"
    source_sha256s["$filename"]="$sha256"
    [[ -n "${fallback_url:-}" ]] && register_source_url "$filename" "$fallback_url"
  done

  for item in "${xorg_library_sources[@]}"; do
    IFS='|' read -r md5 filename <<<"$item"
    register_xorg_source lib "$md5" "$filename"
  done

  for item in "${xorg_application_sources[@]}"; do
    IFS='|' read -r md5 filename <<<"$item"
    register_xorg_source app "$md5" "$filename"
  done

  for item in "${xorg_font_sources[@]}"; do
    IFS='|' read -r md5 filename <<<"$item"
    register_xorg_source font "$md5" "$filename"
  done
}

source_available() {
  local archive="$1"
  local path=""
  local sha256="${source_sha256s[$archive]:-}"
  local md5="${source_md5s[$archive]:-}"

  if [[ -f "$BLFS_SOURCES/$archive" ]]; then
    path="$BLFS_SOURCES/$archive"
  elif [[ -f "$KALYX_SOURCES/$archive" ]]; then
    path="$KALYX_SOURCES/$archive"
  else
    return 1
  fi

  if [[ -n "$sha256" ]]; then
    sha256_ok "$path" "$sha256"
    return $?
  fi

  if [[ -n "$md5" ]]; then
    printf '%s  %s\n' "$md5" "$path" | md5sum -c - >/dev/null 2>&1
    return $?
  fi

  return 0
}

record_failed_download() {
  local archive="$1"
  local existing

  for existing in "${failed_downloads[@]}"; do
    [[ "$existing" == "$archive" ]] && return 0
  done

  failed_downloads+=("$archive")
}

sha256_ok() {
  local filename="$1"
  local sha256="$2"
  [[ -f "$filename" ]] || return 1
  printf '%s  %s\n' "$sha256" "$filename" | sha256sum -c - >/dev/null 2>&1
}

download_extra_source() {
  local filename="$1"
  local sha256="$2"
  shift 2

  local dest="$BLFS_SOURCES/$filename"
  local url

  if sha256_ok "$dest" "$sha256"; then
    info "Fonte extra BLFS ja validada: $filename"
    return 0
  fi

  rm -f "$dest"
  for url in "$@"; do
    [[ -n "$url" ]] || continue
    info "Fonte extra BLFS: $filename"
    info "URL: $url"
    if download_to "$url" "$dest" && sha256_ok "$dest" "$sha256"; then
      printf '%s  %s\n' "$sha256" "$dest" | sha256sum -c -
      return 0
    fi
    warn "Falha baixando ou validando $filename por $url"
    rm -f "$dest"
  done

  warn "Pulando fonte extra BLFS apos falha: $filename"
  record_failed_download "$filename"
  return 1
}

download_plain_source() {
  local archive="$1"
  shift
  local dest="$BLFS_SOURCES/$archive"
  local url

  if source_available "$archive"; then
    info "Fonte ja presente/valida: $archive"
    return 0
  fi

  rm -f "$dest"
  for url in "$@"; do
    [[ -n "$url" ]] || continue
    info "Baixando fonte: $archive"
    info "URL: $url"

    if download_to "$url" "$dest" && source_available "$archive"; then
      return 0
    fi

    warn "Falha baixando ou validando $archive por $url"
    rm -f "$dest"
  done

  warn "Pulando fonte apos falha: $archive"
  record_failed_download "$archive"
  return 1
}

download_registered_source() {
  local archive="$1"
  local urls_text="${source_urls[$archive]:-}"
  local sha256="${source_sha256s[$archive]:-}"
  local urls=()
  local url

  source_available "$archive" && return 0

  while IFS= read -r url; do
    [[ -n "$url" ]] && urls+=("$url")
  done <<< "$urls_text"

  if [[ -n "$sha256" ]]; then
    download_extra_source "$archive" "$sha256" "${urls[@]}"
    return $?
  fi

  if [[ "${#urls[@]}" -eq 0 ]]; then
    record_failed_download "$archive"
    return 1
  fi

  download_plain_source "$archive" "${urls[@]}"
}

check_blfs_manifest_sources() {
  local phase manifest entry recipe archive pkg_name stamp missing=0 skipped_built=0

  info "Conferindo fontes usadas pelos manifestos BLFS da Kalyx"
  for phase in blfs-base desktop; do
    manifest="$KALYX_REPO/recipes/$phase/manifest"
    [[ -f "$manifest" ]] || continue

    while IFS= read -r entry; do
      [[ -z "$entry" || "$entry" == \#* ]] && continue
      recipe="$KALYX_REPO/recipes/$phase/$entry.recipe"
      [[ -f "$recipe" ]] || continue

      pkg_name="$(bash -c 'set -Eeuo pipefail; pkg_name=""; source "$1"; printf "%s\n" "$pkg_name"' _ "$recipe")"
      stamp="$KALYX_ROOTFS/var/lib/kalyx/lfs-stamps/$pkg_name"
      if [[ "${KALYX_FETCH_BUILT:-0}" != "1" && -n "$pkg_name" && -f "$stamp" ]]; then
        info "Pulando fontes de $pkg_name; stamp ja existe em $stamp"
        skipped_built=$((skipped_built + 1))
        continue
      fi

      while IFS= read -r archive; do
        [[ -n "$archive" ]] || continue
        if ! source_available "$archive" && ! download_registered_source "$archive"; then
          warn "Fonte ausente para $phase/$entry: $archive"
          record_failed_download "$archive"
          missing=1
        fi
      done < <(
        sed -n 's/^source_archive="\([^"]*\)"/\1/p' "$recipe"
        sed -n 's/.*"\([^"]*\.\(tar\.xz\|tar\.gz\|tar\.bz2\|tgz\|zip\|patch\)\)".*/\1/p' "$recipe"
      )
    done < "$manifest"
  done

  info "Pacotes ja compilados ignorados pelo fetch: $skipped_built"
  [[ "$missing" -eq 0 ]]
}

report_failed_downloads() {
  local archive

  if [[ "${#failed_downloads[@]}" -eq 0 ]]; then
    return 0
  fi

  warn "Algumas fontes nao puderam ser baixadas/validadas:"
  for archive in "${failed_downloads[@]}"; do
    warn "  - $archive"
  done

  die "Corrija/baixe as fontes acima e rode fetch-blfs-sources novamente."
}

info "Baixando lista oficial BLFS em $BLFS_SOURCES"
info "Workdir: $KALYX_WORKDIR"
info "Sources: $BLFS_SOURCES"
download_to "$BLFS_DOWNLOAD_BASE/wget-list" "$BLFS_SOURCES/wget-list"
register_known_sources

info "Fontes oficiais BLFS serao baixadas sob demanda conforme os manifestos da Kalyx."

info "Registrando checksums Xorg usados pelas receitas"
: > "$BLFS_SOURCES/md5sums"
for item in "${xorg_library_sources[@]}"; do
  IFS='|' read -r md5 filename <<<"$item"
  printf '%s  %s\n' "$md5" "$filename" >> "$BLFS_SOURCES/md5sums"
done

for item in "${xorg_application_sources[@]}"; do
  IFS='|' read -r md5 filename <<<"$item"
  printf '%s  %s\n' "$md5" "$filename" >> "$BLFS_SOURCES/md5sums"
done

for item in "${xorg_font_sources[@]}"; do
  IFS='|' read -r md5 filename <<<"$item"
  printf '%s  %s\n' "$md5" "$filename" >> "$BLFS_SOURCES/md5sums"
done

check_blfs_manifest_sources || true
report_failed_downloads

info "Fontes BLFS baixadas em $BLFS_SOURCES"
