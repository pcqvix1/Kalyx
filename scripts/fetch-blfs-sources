xorg_font_sources=(
  "a6541d12ceba004c0c1e3df900324642|font-util-1.4.1.tar.xz"
)

check_blfs_manifest_sources() {
  local phase manifest entry recipe archive missing=0

  info "Conferindo fontes usadas pelos manifestos BLFS da Kalyx"
  for phase in blfs-base desktop; do
    manifest="$KALYX_REPO/recipes/$phase/manifest"
    [[ -f "$manifest" ]] || continue

    while IFS= read -r entry; do
      [[ -z "$entry" || "$entry" == \#* ]] && continue
      recipe="$KALYX_REPO/recipes/$phase/$entry.recipe"
      [[ -f "$recipe" ]] || continue

      while IFS= read -r archive; do
        [[ -n "$archive" ]] || continue
        if [[ ! -f "$BLFS_SOURCES/$archive" && ! -f "$KALYX_SOURCES/$archive" ]]; then
          warn "Fonte ausente para $phase/$entry: $archive"
          missing=1
        fi
      done < <(
        sed -n 's/^source_archive="\([^"]*\)"/\1/p' "$recipe"
        sed -n 's/.*"\([^"]*\.\(tar\.xz\|tar\.gz\|tar\.bz2\|tgz\|zip\|patch\)\)".*/\1/p' "$recipe"
      )
    done < "$manifest"
  done

  [[ "$missing" -eq 0 ]] || die "Algumas fontes BLFS das receitas ainda estao ausentes."
}

info "Baixando lista oficial BLFS em $BLFS_SOURCES"
info "Workdir: $KALYX_WORKDIR"
info "Sources: $BLFS_SOURCES"
download_to "$BLFS_DOWNLOAD_BASE/wget-list" "$BLFS_SOURCES/wget-list"

info "Baixando fontes BLFS listadas oficialmente"
if command -v wget >/dev/null 2>&1; then
  wget --input-file="$BLFS_SOURCES/wget-list" --continue --directory-prefix="$BLFS_SOURCES"
else
  while IFS= read -r url; do
    [[ -z "$url" || "$url" == \#* ]] && continue
    download_to "$url" "$BLFS_SOURCES/${url##*/}"
  done < "$BLFS_SOURCES/wget-list"
fi

info "Baixando fontes extras orientadas pelo BLFS"
for item in "${extra_sources[@]}"; do
  IFS='|' read -r filename url sha256 <<<"$item"
  info "Fonte extra BLFS: $filename"
  download_to "$url" "$BLFS_SOURCES/$filename"
  printf '%s  %s\n' "$sha256" "$BLFS_SOURCES/$filename" | sha256sum -c -
done

info "Baixando Xorg Libraries listadas no BLFS"
: > "$BLFS_SOURCES/md5sums"
for item in "${xorg_library_sources[@]}"; do
  IFS='|' read -r md5 filename <<<"$item"
  info "Xorg Library: $filename"
  download_to "https://www.x.org/pub/individual/lib/$filename" "$BLFS_SOURCES/$filename"
  printf '%s  %s\n' "$md5" "$BLFS_SOURCES/$filename" | md5sum -c -
  printf '%s  %s\n' "$md5" "$filename" >> "$BLFS_SOURCES/md5sums"
done

info "Baixando Xorg Applications listadas no BLFS"
for item in "${xorg_application_sources[@]}"; do
  IFS='|' read -r md5 filename <<<"$item"
  info "Xorg Application: $filename"
  download_to "https://www.x.org/pub/individual/app/$filename" "$BLFS_SOURCES/$filename"
  printf '%s  %s\n' "$md5" "$BLFS_SOURCES/$filename" | md5sum -c -
  printf '%s  %s\n' "$md5" "$filename" >> "$BLFS_SOURCES/md5sums"
done

info "Baixando Xorg Fonts minimas listadas no BLFS"
for item in "${xorg_font_sources[@]}"; do
  IFS='|' read -r md5 filename <<<"$item"
  info "Xorg Font: $filename"
  download_to "https://www.x.org/pub/individual/font/$filename" "$BLFS_SOURCES/$filename"
  printf '%s  %s\n' "$md5" "$BLFS_SOURCES/$filename" | md5sum -c -
  printf '%s  %s\n' "$md5" "$filename" >> "$BLFS_SOURCES/md5sums"
done

check_blfs_manifest_sources

info "Fontes BLFS baixadas em $BLFS_SOURCES"
