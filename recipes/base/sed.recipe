pkg_name="sed"
pkg_version="4.9"
source_archive="sed-4.9.tar.xz"
source_dir="sed-4.9"

build_recipe() {
  ./configure --prefix=/usr
  make
  make html

  if [[ "${KALYX_RUN_TESTS:-0}" == "1" ]]; then
    chown -R tester .
    su tester -c "PATH=$PATH make check"
  fi

  make install
  install -d -m755 /usr/share/doc/sed-4.9
  install -m644 doc/sed.html /usr/share/doc/sed-4.9
}

