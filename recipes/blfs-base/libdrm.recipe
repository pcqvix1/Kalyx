pkg_name="libdrm"
pkg_version="2.4.131"
source_archive="libdrm-2.4.131.tar.xz"
source_dir="libdrm-2.4.131"

build_recipe() {
  mkdir build
  cd build

  meson setup --prefix=/usr       \
              --buildtype=release \
              -D udev=true        \
              -D valgrind=disabled \
              ..

  ninja

  if [[ "${KALYX_RUN_TESTS:-0}" == "1" ]]; then
    ninja test
  fi

  ninja install
}
