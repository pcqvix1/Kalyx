pkg_name="accountsservice"
pkg_version="23.13.9"
source_archive="accountsservice-23.13.9.tar.xz"
source_dir="accountsservice-23.13.9"

build_recipe() {
  mv tests/dbusmock{,-tests}
  sed -e '/accounts_service\.py/s/dbusmock/dbusmock-tests/' \
      -e 's/assertEquals/assertEqual/'                      \
      -i tests/test-libaccountsservice.py
  sed -i '/^SIMULATED_SYSTEM_LOCALE/s/en_IE.UTF-8/en_HK.iso88591/' tests/test-daemon.py

  mkdir build
  cd build

  meson setup ..            \
        --prefix=/usr       \
        --buildtype=release \
        -D admin_group=wheel \
        -D vapi=false       \
        -D docbook=false    \
        -D gtk_doc=false

  grep 'print_indent'     ../subprojects/mocklibc-1.0/src/netgroup.c \
       | sed 's/ {/;/' >> ../subprojects/mocklibc-1.0/src/netgroup.h
  sed -i '1i#include <stdio.h>' ../subprojects/mocklibc-1.0/src/netgroup.h

  ninja

  if [[ "${KALYX_RUN_TESTS:-0}" == "1" ]]; then
    ninja test || true
  fi

  ninja install

  install -vdm755 /etc/polkit-1/rules.d
  cat > /etc/polkit-1/rules.d/40-wheel.rules <<'EOF'
polkit.addAdminRule(function(action, subject) {
  return ["unix-group:wheel"];
});
EOF
}
