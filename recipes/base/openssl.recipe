pkg_name="openssl"
pkg_version="3.6.1"
source_archive="openssl-3.6.1.tar.gz"
source_dir="openssl-3.6.1"

build_recipe() {
  ./config --prefix=/usr         \
           --openssldir=/etc/ssl \
           --libdir=lib          \
           shared                \
           zlib-dynamic

  make

  if [[ "${KALYX_RUN_TESTS:-0}" == "1" ]]; then
    HARNESS_JOBS="$(nproc)" make test
  fi

  sed -i '/INSTALL_LIBS/s/libcrypto.a libssl.a//' Makefile
  make MANSUFFIX=ssl install
  mv -v /usr/share/doc/openssl /usr/share/doc/openssl-3.6.1
  cp -vfr doc/* /usr/share/doc/openssl-3.6.1
}

