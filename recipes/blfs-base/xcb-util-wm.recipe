pkg_name="xcb-util-wm"
pkg_version="0.4.2"
source_archive="xcb-util-wm-0.4.2.tar.xz"
source_dir="xcb-util-wm-0.4.2"

build_recipe() {
  ./configure --prefix=/usr        \
              --sysconfdir=/etc    \
              --localstatedir=/var \
              --disable-static
  make
  make install
}
