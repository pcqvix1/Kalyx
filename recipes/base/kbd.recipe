pkg_name="kbd"
pkg_version="2.9.0"
source_archive="kbd-2.9.0.tar.xz"
source_dir="kbd-2.9.0"
extra_archives=("kbd-2.9.0-backspace-1.patch")

build_recipe() {
  patch -Np1 -i /sources/kbd-2.9.0-backspace-1.patch

  sed -i '/RESIZECONS_PROGS=/s/yes/no/' configure
  sed -i 's/resizecons.8 //' docs/man/man8/Makefile.in

  ./configure --prefix=/usr --disable-vlock
  make

  if [[ "${KALYX_RUN_TESTS:-0}" == "1" ]]; then
    make check
  fi

  make install
  cp -R -v docs/doc -T /usr/share/doc/kbd-2.9.0
}

