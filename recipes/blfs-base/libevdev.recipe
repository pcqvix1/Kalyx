pkg_name="libevdev"
pkg_version="1.13.6"
source_archive="libevdev-1.13.6.tar.xz"
source_dir="libevdev-1.13.6"

build_recipe() {
  export XORG_PREFIX="/usr"

  mkdir build
  cd build

  meson setup ..                  \
        --prefix="$XORG_PREFIX"   \
        --buildtype=release       \
        -D documentation=disabled \
        -D tests=disabled

  ninja
  ninja install
}
