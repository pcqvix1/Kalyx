pkg_name="itstool"
pkg_version="2.0.7"
source_archive="itstool-2.0.7.tar.gz"
source_dir="itstool-2.0.7"
extra_archives=(
  "itstool-2.0.7-lxml-1.patch"
)

build_recipe() {
  patch -Np1 -i /sources/itstool-2.0.7-lxml-1.patch

  PYTHON=/usr/bin/python3 ./autogen.sh --prefix=/usr
  make

  if [[ "${KALYX_RUN_TESTS:-0}" == "1" ]]; then
    python3 tests/run_tests.py
  fi

  make install
}
