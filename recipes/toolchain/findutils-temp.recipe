pkg_name="findutils-temp"
pkg_version="4.10.0"
source_archive="findutils-4.10.0.tar.xz"
source_dir="findutils-4.10.0"

build_recipe() {
  ./configure --prefix=/usr \
              --localstatedir=/var/lib/locate \
              --host="$LFS_TGT" \
              --build="$(build-aux/config.guess)"

  make
  make DESTDIR="$LFS" install
}

