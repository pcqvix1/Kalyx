pkg_name="libxcrypt"
pkg_version="4.5.2"
source_archive="libxcrypt-4.5.2.tar.xz"
source_dir="libxcrypt-4.5.2"

build_recipe() {
  sed -i '/strchr/s/const//' lib/crypt-{sm3,gost}-yescrypt.c

  ./configure --prefix=/usr                \
              --enable-hashes=strong,glibc \
              --enable-obsolete-api=no     \
              --disable-static             \
              --disable-failure-tokens

  make

  if [[ "${KALYX_RUN_TESTS:-0}" == "1" ]]; then
    make check
  fi

  make install
}

