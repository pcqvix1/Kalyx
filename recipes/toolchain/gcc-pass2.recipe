pkg_name="gcc-pass2"
pkg_version="15.2.0"
source_archive="gcc-15.2.0.tar.xz"
source_dir="gcc-15.2.0"

build_recipe() {
  lfs_verify_archive "mpfr-4.2.2.tar.xz"
  lfs_verify_archive "gmp-6.3.0.tar.xz"
  lfs_verify_archive "mpc-1.3.1.tar.gz"

  lfs_extract_into "mpfr-4.2.2.tar.xz" "$srcdir"
  mv -v mpfr-4.2.2 mpfr

  lfs_extract_into "gmp-6.3.0.tar.xz" "$srcdir"
  mv -v gmp-6.3.0 gmp

  lfs_extract_into "mpc-1.3.1.tar.gz" "$srcdir"
  mv -v mpc-1.3.1 mpc

  case "$(uname -m)" in
    x86_64)
      sed -e '/m64=/s/lib64/lib/' -i.orig gcc/config/i386/t-linux64
    ;;
  esac

  sed '/thread_header =/s/@.*@/gthr-posix.h/' \
    -i libgcc/Makefile.in libstdc++-v3/include/Makefile.in

  mkdir -v build
  cd build

  ../configure \
    --build="$(../config.guess)" \
    --host="$LFS_TGT" \
    --target="$LFS_TGT" \
    --prefix=/usr \
    --with-build-sysroot="$LFS" \
    --enable-default-pie \
    --enable-default-ssp \
    --disable-nls \
    --disable-multilib \
    --disable-libatomic \
    --disable-libgomp \
    --disable-libquadmath \
    --disable-libsanitizer \
    --disable-libssp \
    --disable-libvtv \
    --enable-languages=c,c++ \
    LDFLAGS_FOR_TARGET="-L$PWD/$LFS_TGT/libgcc"

  make
  make DESTDIR="$LFS" install

  ln -sv gcc "$LFS/usr/bin/cc"
}

