pkg_name="expect"
pkg_version="5.45.4"
source_archive="expect5.45.4.tar.gz"
source_dir="expect5.45.4"
extra_archives=("expect-5.45.4-gcc15-1.patch")

build_recipe() {
  python3 -c 'from pty import spawn; spawn(["echo", "ok"])'
  patch -Np1 -i /sources/expect-5.45.4-gcc15-1.patch

  ./configure --prefix=/usr           \
              --with-tcl=/usr/lib     \
              --enable-shared         \
              --disable-rpath         \
              --mandir=/usr/share/man \
              --with-tclinclude=/usr/include

  make

  if [[ "${KALYX_RUN_TESTS:-0}" == "1" ]]; then
    make test
  fi

  make install
  ln -svf expect5.45.4/libexpect5.45.4.so /usr/lib
}

